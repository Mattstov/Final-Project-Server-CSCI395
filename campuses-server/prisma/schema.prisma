generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Campus {
  id          Int       @id @default(autoincrement())
  name        String
  address     String
  imageUrl    String    @default("https://placehold.co/400x300?text=Campus")
  description String
  students    Student[]
}

model Student {
  id         Int     @id @default(autoincrement())
  firstName  String
  lastName   String
  email      String  @unique
  imageUrl   String  @default("https://placehold.co/400x300?text=Student")
  gpa        Float
  campusId   Int?
  campus     Campus? @relation(fields: [campusId], references: [id])
}